{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "chem",
  "version": "0.1.0",
  "identifier": "com.moyanxinxu.dev",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "chem",
        "width": 1200,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU5NkQxQTkwODAzMkFFOEQKUldTTnJqS0FrQnB0V1dQQXRYd1d1dkdqSmhUb0lPUDRBSVhha3Ivak9sSEtoc0JlR0tYcTl3YXoK",
      "endpoints": [
        "https://github.com/moyanxinxu/chem/releases/latest/download/latest.json"
      ]
    }
  }
}
